# ============================================================
# Mehad Automation — Environment Variables Reference
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real credentials.
# ============================================================

# ── Target URL ───────────────────────────────────────────────────────────────
BASE_URL=https://dev.mehadedu.com/en        # staging (default)
# BASE_URL=https://mehadedu.com/en          # production

# ── Staging / Dev credentials (fixed OTP — no real SMS/WhatsApp needed) ──────
TEST_PHONE=98976564          # registered staging account
TEST_COUNTRY=+880            # Bangladesh
TEST_OTP=123456              # server always returns this on staging

TEACHER_PHONE=98976564
TEACHER_OTP=123456
STUDENT_PHONE=98976564
STUDENT_OTP=123456

# ── Production OTP backend — choose ONE of the options below ─────────────────
# NOTE: Mehad sends OTPs via WhatsApp, not SMS.
#   • For WhatsApp OTPs → use "waha" or "whatsapp_local"
#   • For SMS fallback  → use "receivesmsfast", "quackr", or "smsonline"

PROD_OTP_BACKEND=waha        # recommended free option for WhatsApp

# ── Option 1: WAHA — free open-source WhatsApp HTTP API (recommended) ────────
# docker run -p 3000:3000 devlikeapro/waha
# Then open http://localhost:3000/dashboard and scan QR with your test phone.
# Works with any country — Bangladesh (+880), Saudi Arabia (+966), USA (+1), etc.
WAHA_URL=http://localhost:3000
WAHA_SESSION=default
WAHA_CHAT_ID=+8801755572498@c.us   # your test number in WhatsApp chat ID format
PROD_COUNTRY_CODE=+880
PROD_TEST_PHONE=1755572498         # local part of the test number

# ── Option 2: whatsapp-web.js local bridge (OSS, needs Node.js) ───────────────
# cd scripts && npm install && node whatsapp_otp_server.js  → scan QR once
# PROD_OTP_BACKEND=whatsapp_local
# WA_OTP_PORT=3001

# ── Option 3: receivesmsfast.com — free, no account (SMS only, BD numbers) ───
# Good for: https://receivesmsfast.com/messages?n=8801755572498
# PROD_OTP_BACKEND=receivesmsfast
# RECEIVESMSFAST_NUMBER=8801755572498    # full number without +

# ── Option 4: quackr.io — free, no account (SMS only, US/EU/many countries) ──
# PROD_OTP_BACKEND=quackr
# QUACKR_NUMBER=12025551234              # full number without +

# ── Option 5: sms-online.co — free, no account (SMS only, many countries) ────
# PROD_OTP_BACKEND=smsonline
# SMSONLINE_NUMBER=12025551234

# ── Option 6: Twilio (paid — WhatsApp API) ────────────────────────────────────
# PROD_OTP_BACKEND=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Production phone numbers ──────────────────────────────────────────────────
PROD_TEACHER_PHONE=1755572498
PROD_STUDENT_PHONE=1755572498

# ── Optional overrides ────────────────────────────────────────────────────────
# LOGIN_URL=https://dev.mehadedu.com/en   # force a specific login URL
