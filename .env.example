# ============================================================
# Mehad Automation — Environment Variables Reference
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real credentials.
# ============================================================

# ── Target URL ───────────────────────────────────────────────────────────────
# Staging (default)
BASE_URL=https://dev.mehadedu.com/en
# Production — set this to run against live site
# BASE_URL=https://mehadedu.com/en

# ── Staging / Dev credentials (fixed OTP, no real SMS needed) ────────────────
TEST_PHONE=98976564          # local number, no country code
TEST_COUNTRY=+880            # Bangladesh dial code
TEST_OTP=123456              # hardcoded OTP returned by staging server

# Separate teacher / student phones (if different accounts on staging)
TEACHER_PHONE=98976564
TEACHER_OTP=123456
STUDENT_PHONE=98976564
STUDENT_OTP=123456

# ── Production credentials (Twilio WhatsApp OTP) ─────────────────────────────
# Required only when BASE_URL points to mehadedu.com (no "dev." prefix)

PROD_OTP_BACKEND=twilio      # twilio | fixed | manual

# Virtual phone numbers registered with the app (Saudi Arabia recommended)
PROD_COUNTRY_CODE=+966
PROD_TEST_PHONE=561234567    # shared fallback number
PROD_TEACHER_PHONE=561234567 # tutor virtual number
PROD_STUDENT_PHONE=567654321 # student virtual number

# Twilio credentials — used by scripts/get_otp.py to fetch WhatsApp OTPs
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886   # Twilio sandbox or your production number

# ── Optional overrides ────────────────────────────────────────────────────────
# Force a specific login URL (defaults to BASE_URL)
# LOGIN_URL=https://dev.mehadedu.com/en

# Email/password auth (not used by Mehad — OTP only, kept for legacy compat)
# TEST_EMAIL=
# TEST_PASSWORD=
